OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.llmapi.ai/v1
POSTGRES_PASSWORD=
JWT_SECRET=

# Public HTTPS origins configured in Coolify.
DASHBOARD_URL=https://mem0.example.com
API_URL=https://mem0-api.example.com
MEM0_MCP_DOMAIN=mcp.mem0.example.com

# Optional, but useful for legacy or server-to-server access.
ADMIN_API_KEY=

# MCP gateway for remote agents. Use a random value and expose only this token
# to clients. MCP_MEM0_API_KEY can be a dedicated self-hosted Mem0 API key; if
# omitted, the gateway falls back to ADMIN_API_KEY.
MCP_GATEWAY_TOKEN=
MCP_GATEWAY_USER_ID=wiselancer
MCP_GATEWAY_AGENT_ID=agent
MCP_GATEWAY_RUN_ID=
MCP_MEM0_API_KEY=

POSTGRES_USER=postgres
POSTGRES_COLLECTION_NAME=memories
NEXT_PUBLIC_INSTANCE_NAME=Mem0
MEM0_DEFAULT_LLM_MODEL=gpt-4.1-nano-2025-04-14
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_TELEMETRY=false
REQUEST_LOG_RETENTION_DAYS=30
